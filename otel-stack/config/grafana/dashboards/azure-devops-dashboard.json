{
  "dashboard": {
    "id": null,
    "title": "Azure DevOps Agent Dashboard",
    "tags": ["azure-devops", "opentelemetry", "metrics", "azure", "devops"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Agent Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"azure-devops-agent\"}",
            "legendFormat": "Agent Status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 0.5
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Work Items / Second",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(workitems_processed_total[5m])",
            "legendFormat": "Work Items/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 4, "y": 0}
      },
      {
        "id": 3,
        "title": "Authentication Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(authentication_attempts_total[5m])",
            "legendFormat": "Auth Attempts/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 8, "y": 0}
      },
      {
        "id": 4,
        "title": "API Call Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(api_calls_total[5m])",
            "legendFormat": "API Calls/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 12, "y": 0}
      },
      {
        "id": 5,
        "title": "Active Work Items",
        "type": "stat",
        "targets": [
          {
            "expr": "workitems_active",
            "legendFormat": "Active Items",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 16, "y": 0}
      },
      {
        "id": 6,
        "title": "Authentication Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "authentication_success_rate",
            "legendFormat": "Authentication Success Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "red"
                },
                {
                  "value": 0.9,
                  "color": "yellow"
                },
                {
                  "value": 0.95,
                  "color": "green"
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8}
      },
      {
        "id": 7,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "memory_usage",
            "legendFormat": "Memory Usage",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "MB",
            "min": 0,
            "max": 1000,
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 500,
                  "color": "yellow"
                },
                {
                  "value": 750,
                  "color": "red"
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8}
      },
      {
        "id": 8,
        "title": "API Response Time Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(api_response_time_bucket[5m]))",
            "legendFormat": "P95 Response Time",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(api_response_time_bucket[5m]))",
            "legendFormat": "P50 Response Time",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 9,
        "title": "Work Item Processing Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(workitems_processed_total[5m])",
            "legendFormat": "Processing Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 10,
        "title": "API Call Trends",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(api_calls_total[5m])",
            "legendFormat": "API Call Rate",
            "refId": "A"
          },
          {
            "expr": "rate(api_success_calls_total[5m])",
            "legendFormat": "Successful API Calls",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s",
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  },
  "folderId": 0,
  "message": "Enhanced Azure DevOps Agent dashboard"
}