{
  "dashboard": {
    "id": null,
    "title": "Autonomous Agent Dashboard",
    "tags": ["autonomous-agent", "opentelemetry", "metrics", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Agent Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"autonomous-agent\"}",
            "legendFormat": "Agent Status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 0.5
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Tasks / Second",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(tasks_executed_total[5m])",
            "legendFormat": "Tasks/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 4, "y": 0}
      },
      {
        "id": 3,
        "title": "Self-Tests Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(selftests_completed_total[5m])",
            "legendFormat": "Tests/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 8, "y": 0}
      },
      {
        "id": 4,
        "title": "LLM Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(llm_requests_total[5m])",
            "legendFormat": "Requests/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 12, "y": 0}
      },
      {
        "id": 5,
        "title": "Scheduling Iterations",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(scheduling_iterations_total[5m])",
            "legendFormat": "Iterations/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 4, "x": 16, "y": 0}
      },
      {
        "id": 6,
        "title": "CPU Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "cpu_usage",
            "legendFormat": "CPU Usage",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 80,
                  "color": "yellow"
                },
                {
                  "value": 90,
                  "color": "red"
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8}
      },
      {
        "id": 7,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "memory_usage",
            "legendFormat": "Memory Usage",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "MB",
            "min": 0,
            "max": 1000,
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 500,
                  "color": "yellow"
                },
                {
                  "value": 750,
                  "color": "red"
                }
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8}
      },
      {
        "id": 8,
        "title": "Task Execution Time Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(task_execution_time_bucket[5m]))",
            "legendFormat": "P95 Execution Time",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(task_execution_time_bucket[5m]))",
            "legendFormat": "P50 Execution Time",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 9,
        "title": "LLM Response Time Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(llm_response_time_bucket[5m]))",
            "legendFormat": "P95 Response Time",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(llm_response_time_bucket[5m]))",
            "legendFormat": "P50 Response Time",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 10,
        "title": "Scheduling Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(scheduling_iterations_total[5m])",
            "legendFormat": "Scheduling Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "refresh": "30s",
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  },
  "folderId": 0,
  "message": "Enhanced Autonomous Agent dashboard"
}